PUBLIC_SITE_URL=https://colburnoutdoor.com
API_PORT=5190
SQLITE_PATH=./data/colburn-leads.sqlite

# Required for owner dashboard access. Local fallback is colburn-admin if omitted.
DASHBOARD_PASSWORD=replace-with-a-strong-password

# Owner notification targets
OWNER_PHONE=7044305221
OWNER_EMAIL=jeff@example.com

# Phase 1 email notifications. Resend is recommended on Cloudflare Pages Functions.
RESEND_API_KEY=replace-with-resend-api-key
EMAIL_FROM=Colburn Outdoor Maintenance <notifications@colburnoutdoor.com>

# Optional SMTP notifications for local/Node server deployments
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=Colburn Outdoor Maintenance <notifications@example.com>

# Optional SMS automation. Keep disabled until Twilio/A2P 10DLC verification is complete.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=replace-with-twilio-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-token
TWILIO_FROM_NUMBER=+17045550123
MISSED_CALL_COOLDOWN_HOURS=24
MISSED_CALL_REPLY=Thanks for calling Colburn Outdoor Maintenance. Sorry we missed you - what outdoor work do you need help with? You can reply here or request a quote at https://colburnoutdoor.com/#contact
SEND_CUSTOMER_CONFIRMATION=false
GOOGLE_REVIEW_LINK=https://g.page/r/YOUR_REVIEW_LINK/review
