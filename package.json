{
  "name": "colburn-outdoor-maintenance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "set NODE_ENV=production&& node server/index.js",
    "preview": "vite preview --host 127.0.0.1",
    "cf:dev": "npm run build && wrangler dev",
    "cf:d1:create": "wrangler d1 create colburnoutdoor-leads",
    "cf:d1:migrate:local": "wrangler d1 migrations apply colburnoutdoor-leads --local",
    "cf:d1:migrate:remote": "wrangler d1 migrations apply colburnoutdoor-leads --remote",
    "cf:deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "nodemailer": "^8.0.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "wrangler": "^4.97.0"
  }
}
